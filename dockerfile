FROM golang:1.26.1@sha256:e2ddb153f786ee6210bf8c40f7f35490b3ff7d38be70d1a0d358ba64225f6428 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o animal-service .

FROM scratch
WORKDIR /root/
COPY --from=builder /app/animal-service .
EXPOSE 8080
CMD ["./animal-service"]